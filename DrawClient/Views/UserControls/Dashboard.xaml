<UserControl x:Class="DrawClient.Views.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DrawClient.Views"
             mc:Ignorable="d" d:DesignHeight="768" d:DesignWidth="1024"
             Background="#FFFFFF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="CollabDraw" FontSize="22" Foreground="#5F6368" VerticalAlignment="Center" Margin="0,0,24,0"/>

                <Border Background="#F1F3F4" CornerRadius="8" Padding="12,8" MaxWidth="600" HorizontalAlignment="Left" Width="664" Margin="80,1,0,0" Grid.Column="1">
                    <Grid>
                        <Path Data="M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z M21 21l-4.3-4.3" 
          Stroke="#5F6368" StrokeThickness="1.5" Fill="Transparent"
          Width="20" Height="20" HorizontalAlignment="Left" VerticalAlignment="Center"
          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.619,0.608" Stretch="Fill"/>

                        <TextBox x:Name="txtSearch" 
             Background="Transparent" BorderThickness="0" Margin="32,0,0,0" 
             FontSize="14" Foreground="#202124" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Search rooms" Foreground="#5F6368" FontSize="14" 
               VerticalAlignment="Center" Margin="32,0,0,0" 
               IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Width="32" Height="32" Background="#1A73E8" CornerRadius="16">
                    <TextBlock Text="JD" Foreground="White" FontSize="14" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Background="#F8F9FA">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="256"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" Padding="32" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- THAY THẾ NÚT "+ NEW ROOM" BẰNG KHỐI NÀY -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- KHU VỰC TẠO PHÒNG MỚI -->
                        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Create New Room" FontSize="16" FontWeight="Medium" Foreground="#202124" Margin="0,0,0,16"/>

                                <TextBlock Text="Room Name" Foreground="#5F6368" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding NewRoomName, UpdateSourceTrigger=PropertyChanged}" Height="36" Padding="8,0" BorderBrush="#DADCE0" VerticalContentAlignment="Center" Margin="0,0,0,12"/>

                                <TextBlock Text="Password (Optional)" Foreground="#5F6368" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding NewRoomPassword, UpdateSourceTrigger=PropertyChanged}" Height="36" Padding="8,0" BorderBrush="#DADCE0" VerticalContentAlignment="Center" Margin="0,0,0,12"/>

                                <CheckBox Content="Private Room" IsChecked="{Binding NewRoomIsPrivate}" Foreground="#5F6368" Margin="0,0,0,16"/>

                                <Button Content="Create Room" Command="{Binding CreateRoomCommand}" 
                    Background="#1A73E8" Foreground="White" FontSize="14" FontWeight="Medium" Height="36" BorderThickness="0">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- KHU VỰC VÀO PHÒNG BẰNG ID & MẬT KHẨU -->
                        <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Join Room via ID" FontSize="16" FontWeight="Medium" Foreground="#202124" Margin="0,0,0,16"/>

                                <TextBlock Text="Room ID" Foreground="#5F6368" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding JoinRoomIdStr, UpdateSourceTrigger=PropertyChanged}" Height="36" Padding="8,0" BorderBrush="#DADCE0" VerticalContentAlignment="Center" Margin="0,0,0,12"/>

                                <TextBlock Text="Password" Foreground="#5F6368" FontSize="12" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding JoinRoomPassword, UpdateSourceTrigger=PropertyChanged}" Height="36" Padding="8,0" BorderBrush="#DADCE0" VerticalContentAlignment="Center" Margin="0,0,0,33"/>
                                <!-- Margin 33 để căn ngang với ô Create -->

                                <Button Content="Join Room" Command="{Binding JoinManualCommand}" 
                    Background="#34A853" Foreground="White" FontSize="14" FontWeight="Medium" Height="36" BorderThickness="0">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <!-- KẾT THÚC PHẦN THAY THẾ -->

                    <TextBlock Text="ACTIVE ROOMS" FontSize="14" FontWeight="Medium" Foreground="#5F6368" Margin="0,0,0,16"/>

                    <ItemsControl ItemsSource="{Binding Rooms}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFFFFF" BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="8" Width="300" Margin="0,0,16,16" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Medium" Foreground="#202124" Margin="0,0,0,12"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Border Width="24" Height="24" Background="#E8F0FE" CornerRadius="12">
                                                    <TextBlock Text="{Binding HostAvatar}" Foreground="#1A73E8" FontSize="11" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding Host}" FontSize="13" Foreground="#5F6368" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </StackPanel>

                                            <Border Grid.Column="1" Background="#F1F3F4" CornerRadius="12" Padding="8,4">
                                                <TextBlock Text="{Binding PlayerCountText}" FontSize="12" Foreground="#5F6368"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#E8EAED" BorderThickness="1,0,0,0" Padding="24">
                <StackPanel>
                    <TextBlock Text="Server Status" FontSize="14" FontWeight="Medium" Foreground="#202124" Margin="0,0,0,12"/>

                    <Border Background="#F8F9FA" CornerRadius="8" Padding="12">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#34A853" Margin="0,0,12,0"/>
                            <TextBlock Text="Connected to Node 1" FontSize="13" Foreground="#5F6368" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="#E8EAED" Margin="0,16"/>

                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Active Rooms" FontSize="12" Foreground="#5F6368" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding ActiveRoomsCount}" FontSize="12" FontWeight="Medium" Foreground="#202124" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid>
                        <TextBlock Text="Total Players" FontSize="12" Foreground="#5F6368" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding TotalPlayers}" FontSize="12" FontWeight="Medium" Foreground="#202124" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>