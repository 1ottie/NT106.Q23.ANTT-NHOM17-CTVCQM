<UserControl x:Class="DrawClient.Views.UserControls.Canvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DrawClient.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#FFFFFF">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="VectorToolStyle" TargetType="Button" >
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="borderBg" 
                            CornerRadius="20" 
                            Background="{TemplateBinding Background}">

                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="4"
                                  Width="18" Height="18"/>

                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="borderBg" Property="Background" Value="#F1F3F4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="borderBg" Property="Background" Value="#E8F0FE"/>
                                <Setter Property="Foreground" Value="#1A73E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RadioToolStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border CornerRadius="20" Background="{TemplateBinding Background}">
                            <Path Data="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
      Stroke="{TemplateBinding Foreground}"
      StrokeThickness="1.5"
      Fill="Transparent"
      Stretch="Uniform"
      Width="18" Height="18"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      StrokeLineJoin="Round"
      StrokeStartLineCap="Round"
      StrokeEndLineCap="Round"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#E8F0FE"/>
                                <Setter Property="Foreground" Value="#1A73E8"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="#F1F3F4"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 1. STYLE Menu Items -->
        <Style x:Key="MaterialComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F3F4"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8F0FE"/>
                                <Setter Property="Foreground" Value="#1A73E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 2. NÚT BẤM CỦA COMBOBOX -->
        <ControlTemplate x:Key="MaterialComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Border x:Name="border" Background="#FFFFFF" BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="4" SnapsToDevicePixels="True"/>
                <Border x:Name="focusBorder" Background="Transparent" BorderBrush="#1A73E8" BorderThickness="2" CornerRadius="4" Opacity="0" SnapsToDevicePixels="True"/>
                <Path x:Name="arrow" Data="M 0,0 L 4,5 L 8,0 Z" Fill="#5F6368" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="BorderBrush" Value="#5F6368"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="focusBorder" Property="Opacity" Value="1"/>
                    <Setter TargetName="border" Property="Opacity" Value="0"/>
                    <Setter TargetName="arrow" Property="Fill" Value="#1A73E8"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <!-- 3. STYLE CHÍNH CHO COMBOBOX -->
        <Style x:Key="MaterialComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                      Template="{StaticResource MaterialComboBoxToggleButton}" 
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Focusable="False"/>
                            <ContentPresenter IsHitTestVisible="False" 
                                          Content="{TemplateBinding SelectionBoxItem}" 
                                          Margin="12,8,30,8" 
                                          VerticalAlignment="Center" 
                                          HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#FFFFFF" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="4" Margin="0,4,0,8"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="#3C4043"/>
                                    </Border.Effect>
                                    <ScrollViewer SnapsToDevicePixels="True" MaxHeight="200">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- STYLE CHO CÁC NÚT CHỌN MÀU (Viền xám, hover đậm viền, không bị xanh) -->
        <Style x:Key="OutlinedColorButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            CornerRadius="4" 
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Khi di chuột vào: Đậm viền lên màu #5F6368 và nền hơi xám nhẹ-->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#5F6368"/>
                                <Setter TargetName="border" Property="Background" Value="#F8F9FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Navigation -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="24,0" Panel.ZIndex="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!--Nút rời phòng-->
                    <Button Command="{Binding LeaveRoomCommand}" Background="Transparent" BorderThickness="0" Margin="0,0,16,0" Cursor="Hand" ToolTip="Leave Room" Style="{StaticResource VectorToolStyle}" Width="36">
                        <Path Data="M 18,2 L 6,12 18,22"
      Stroke="Black"
      StrokeThickness="1.5"
      StrokeLineJoin="Round"
      StrokeStartLineCap="Round"
      StrokeEndLineCap="Round"
      Fill="Transparent"
      Stretch="Uniform"
      Width="18" Height="18" RenderTransformOrigin="0.685,0.461" Margin="-2,0,0,0"
                              />
                    </Button>
                    <!--Tên phòng-->
                    <Rectangle Width="1" Height="24" Margin="0,0,5,0"/>

                    <Button Command="{Binding ShowRoomInfoCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,20,0">
                        <Button.ToolTip>
                            <ToolTip Content="Nhấp để xem Mã phòng và Mật khẩu"/>
                        </Button.ToolTip>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{Binding RoomName}" FontSize="16" FontWeight="SemiBold" Foreground="#202124" VerticalAlignment="Center" RenderTransformOrigin="0.664,0.608"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Rectangle Width="1" Height="24" Fill="#E8EAED" Margin="0,0,16,0"/>

                    <!--UNDO-->
                    <Button Width="36" Height="36" Background="Transparent" BorderThickness="0" Margin="0,0,8,0" ToolTip="Undo" Cursor="Hand" Style="{StaticResource VectorToolStyle}">
                        <Path Data="M3 7v6h6 M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"
			                  Stroke="#5F6368" StrokeThickness="1.5" Fill="Transparent"
			                  Width="18" Height="18" Stretch="Uniform"
			                  HorizontalAlignment="Center" VerticalAlignment="Center"
			                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>
                    <!--REDO-->
                    <Button Width="36" Height="36" Background="Transparent" BorderThickness="0" ToolTip="Redo" Cursor="Hand" Style="{StaticResource VectorToolStyle}">
                        <Path Data="M21 7v6h-6 M3 17a9 9 0 0 1 9-9 9 9 0 0 1 6 2.3l3 2.7"
			                  Stroke="#5F6368" StrokeThickness="1.5" Fill="Transparent"
			                  Width="18" Height="18" Stretch="Uniform"
			                  HorizontalAlignment="Center" VerticalAlignment="Center"
			                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>
                </StackPanel>
                <!--THANH REPLAY-->
                <Border Grid.Column="1" Background="#F8F9FA" CornerRadius="8" Margin="40,12" Padding="16,0" MaxWidth="500">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Width="36" Height="36" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Cursor="Hand" Style="{StaticResource VectorToolStyle}">
                            <Path Data="M5 3 L19 12 L5 21 Z"
                  Stroke="#5F6368" StrokeThickness="1.5" Fill="Transparent"
                  Width="16" Height="16" Stretch="Uniform"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  StrokeLineJoin="Round" StrokeStartLineCap="Round" Margin="2.5,0,0,0"/>
                        </Button>

                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center" Margin="16,0">
                            <Slider.Template>
                                <ControlTemplate TargetType="Slider">
                                    <Grid VerticalAlignment="Center">

                                        <Border Height="4" Background="#DADCE0" CornerRadius="2" VerticalAlignment="Center"/>

                                        <Track x:Name="PART_Track">

                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="RepeatButton">
                                                            <Border Height="4" Background="#1A73E8" CornerRadius="2,0,0,2" VerticalAlignment="Center"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.DecreaseRepeatButton>

                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="RepeatButton">
                                                            <Border Background="Transparent"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.IncreaseRepeatButton>

                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Ellipse Width="14" Height="14" Fill="#1A73E8">
                                                                <Ellipse.Effect>
                                                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.25" Color="#3C4043"/>
                                                                </Ellipse.Effect>
                                                            </Ellipse>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>

                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Slider.Template>
                        </Slider>

                        <TextBlock Grid.Column="2" Text="0%" Foreground="#5F6368" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="13"/>
                    </Grid>
                </Border>
                <!--USER-->
                <Border Grid.Column="2" Width="32" Height="32" Background="#1A73E8" CornerRadius="16">
                    <TextBlock Text="JD" Foreground="White" FontSize="14" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

            </Grid>

        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" ClipToBounds="True">

                <!--Thay đổi cấu hình sự kiện và vô hiệu hóa chế độ vẽ nội bộ của InkCanvas -->
                <InkCanvas x:Name="MyCanvas" Grid.Column="0" 
                           EditingMode="None"
                           MouseDown="Canvas_MouseDown" 
                           MouseUp="Canvas_MouseUp" 
                           MouseMove="Canvas_MouseMove">
                    <InkCanvas.Background>
                        <DrawingBrush Viewport="0,0,30,30" ViewportUnits="Absolute" TileMode="Tile" Stretch="None">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing Brush="#B0B5B9">
                                    <GeometryDrawing.Geometry>
                                        <EllipseGeometry RadiusX="1" RadiusY="1" Center="0,0"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </InkCanvas.Background>
                </InkCanvas>

                <Canvas Panel.ZIndex="2" IsHitTestVisible="False">

                    <Canvas Canvas.Left="350" Canvas.Top="200"/>

                    <Canvas Canvas.Left="480" Canvas.Top="320"/>
                </Canvas>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="24,0,0,0" Panel.ZIndex="100">
                    <Border VerticalAlignment="Center" Margin="24,0,0,0" Background="#FFFFFF" CornerRadius="24" Padding="4,12" Panel.ZIndex="5" Width="52">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="#3C4043"/>
                        </Border.Effect>
                        <!-- Toolbox -->
                        <StackPanel Width="40">
                            <RadioButton GroupName="Tools" Width="40" Height="40" Margin="0,0,0,8" IsChecked="True" ToolTip="Select" Style="{StaticResource RadioToolStyle}"
                     Content="M4.037 4.688a.495.495 0 0 1 .651-.651l16 6.5a.5.5 0 0 1-.063.947l-6.124 1.58a2 2 0 0 0-1.438 1.435l-1.579 6.126a.5.5 0 0 1-.947.063z"/>

                            <RadioButton GroupName="Tools" Width="40" Height="40" Margin="0,0,0,8" ToolTip="Pen" Style="{StaticResource RadioToolStyle}"
                                         IsChecked="{Binding IsPenSelected, Mode=TwoWay}"
                                         Command="{Binding SelectToolCommand}" CommandParameter="pen"
                     Content="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z M15 5l4 4"/>

                            <RadioButton GroupName="Tools" Width="40" Height="40" Margin="0,0,0,8" ToolTip="Eraser" Style="{StaticResource RadioToolStyle}"
                                         IsChecked="{Binding IsEraserSelected, Mode=TwoWay}"
                                         Command="{Binding SelectToolCommand}" CommandParameter="eraser"
                     Content="m7 21-4.3-4.3c-1-1-1-2.5 0-3.4l9.6-9.6c1-1 2.5-1 3.4 0l5.6 5.6c1 1 1 2.5 0 3.4L13 21 M22 21H7 M5 11l9 9"/>

                            <RadioButton GroupName="Tools" Width="40" Height="40" Margin="0,0,0,8" ToolTip="Shapes" Style="{StaticResource RadioToolStyle}"
                                         IsChecked="{Binding IsShapesSelected, Mode=TwoWay}"
                                         Command="{Binding SelectToolCommand}" CommandParameter="shapes"
                     Content="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/>

                            <RadioButton GroupName="Tools" Width="40" Height="40" Margin="0,0,0,8" ToolTip="Text" Style="{StaticResource RadioToolStyle}"
                                         IsChecked="{Binding IsTextSelected, Mode=TwoWay}"
             Command="{Binding SelectToolCommand}" CommandParameter="text"
                     Content="M4 7V4h16v3 M9 20h6 M12 4v16"/>

                            <RadioButton GroupName="Tools" Width="40" Height="40" ToolTip="OCR Magic" Style="{StaticResource RadioToolStyle}"
                     Content="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72Z M14 7l3 3 M5 6v4 M19 14v4 M10 2h.01 M20 22h.01 M2 2h.01"/>
                        </StackPanel>
                    </Border>
                    <Grid>
                        <!-- 1. POPOVER BÚT -->
                        <Border x:Name="PenPopover" 
            Background="#FFFFFF" CornerRadius="12" Margin="12,50,0,0" Padding="16" Width="220"
            VerticalAlignment="Top"
            Visibility="{Binding IsPenPopoverVisible, Converter={StaticResource BoolToVis}}"
            d:Visibility="Hidden" Height="158">

                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.15" Color="#3C4043"/>
                            </Border.Effect>

                            <StackPanel>
                                <!-- Chọn màu -->
                                <TextBlock Text="COLOR" FontSize="12" FontWeight="Medium" Foreground="#5F6368" Margin="0,0,0,8"/>
                                <Button Command="{Binding TogglePaletteCommand}" Style="{StaticResource OutlinedColorButtonStyle}" Background="Transparent" BorderBrush="#DADCE0" BorderThickness="1" Cursor="Hand" Margin="0,0,0,16" Padding="8,4">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="20" Height="20" Background="#202124" CornerRadius="4" BorderBrush="#DADCE0" BorderThickness="1" Margin="0,0,8,0"/>
                                        <TextBlock Text="Choose color" Foreground="#5F6368" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Chọn độ dày -->
                                <TextBlock Text="THICKNESS" FontSize="12" FontWeight="Medium" Foreground="#5F6368" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" Data="M0,0 L16,0" Stroke="#5F6368" StrokeThickness="1" VerticalAlignment="Center"/>
                                    <!-- Binding tới PenThickness -->
                                    <Slider Grid.Column="1" Minimum="1" Maximum="20" Value="{Binding PenThickness, Mode=TwoWay}" Margin="8,0" Foreground="#1A73E8">
                                        <!-- Slider -->
                                        <Slider.Template>
                                            <ControlTemplate TargetType="Slider">
                                                <Grid VerticalAlignment="Center">
                                                    <Border Height="4" Background="#DADCE0" CornerRadius="2" VerticalAlignment="Center"/>
                                                    <Track x:Name="PART_Track">
                                                        <Track.DecreaseRepeatButton>
                                                            <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                                                <RepeatButton.Template>
                                                                    <ControlTemplate TargetType="RepeatButton">
                                                                        <Border Height="4" Background="#1A73E8" CornerRadius="2,0,0,2" VerticalAlignment="Center"/>
                                                                    </ControlTemplate>
                                                                </RepeatButton.Template>
                                                            </RepeatButton>
                                                        </Track.DecreaseRepeatButton>
                                                        <Track.IncreaseRepeatButton>
                                                            <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                                                <RepeatButton.Template>
                                                                    <ControlTemplate TargetType="RepeatButton">
                                                                        <Border Background="Transparent"/>
                                                                    </ControlTemplate>
                                                                </RepeatButton.Template>
                                                            </RepeatButton>
                                                        </Track.IncreaseRepeatButton>
                                                        <Track.Thumb>
                                                            <Thumb>
                                                                <Thumb.Template>
                                                                    <ControlTemplate TargetType="Thumb">
                                                                        <Ellipse Width="14" Height="14" Fill="#1A73E8">
                                                                            <Ellipse.Effect>
                                                                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.25" Color="#3C4043"/>
                                                                            </Ellipse.Effect>
                                                                        </Ellipse>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Track.Thumb>
                                                    </Track>
                                                </Grid>
                                            </ControlTemplate>
                                        </Slider.Template>
                                    </Slider>
                                    <Path Grid.Column="2" Data="M0,0 L18,0" Stroke="#5F6368" StrokeThickness="4" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <!-- 2. POPOVER TẨY -->
                        <Border x:Name="EraserPopover" 
                    Background="#FFFFFF" CornerRadius="12" Margin="12,98,0,0" Padding="16" Width="220" Height="88"
                    VerticalAlignment="Top"
                    Visibility="{Binding IsEraserPopoverVisible, Converter={StaticResource BoolToVis}}"
                    d:Visibility="Hidden">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.15" Color="#3C4043"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock Text="THICKNESS" FontSize="12" FontWeight="Medium" Foreground="#5F6368" Margin="0,0,0,8"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Rectangle Grid.Column="0" Width="16" Height="1.5" Fill="#5F6368" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider Grid.Column="1" Minimum="1" Maximum="30" Value="{Binding EraserThickness, Mode=TwoWay}" Foreground="#1A73E8">
                                        <Slider.Template>
                                            <ControlTemplate TargetType="Slider">
                                                <Grid VerticalAlignment="Center">
                                                    <Border Height="4" Background="#DADCE0" CornerRadius="2" VerticalAlignment="Center"/>
                                                    <Track x:Name="PART_Track">
                                                        <Track.DecreaseRepeatButton>
                                                            <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                                                <RepeatButton.Template>
                                                                    <ControlTemplate TargetType="RepeatButton">
                                                                        <Border Height="4" Background="#1A73E8" CornerRadius="2,0,0,2" VerticalAlignment="Center"/>
                                                                    </ControlTemplate>
                                                                </RepeatButton.Template>
                                                            </RepeatButton>
                                                        </Track.DecreaseRepeatButton>
                                                        <Track.IncreaseRepeatButton>
                                                            <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                                                <RepeatButton.Template>
                                                                    <ControlTemplate TargetType="RepeatButton">
                                                                        <Border Background="Transparent"/>
                                                                    </ControlTemplate>
                                                                </RepeatButton.Template>
                                                            </RepeatButton>
                                                        </Track.IncreaseRepeatButton>
                                                        <Track.Thumb>
                                                            <Thumb>
                                                                <Thumb.Template>
                                                                    <ControlTemplate TargetType="Thumb">
                                                                        <Ellipse Width="14" Height="14" Fill="#1A73E8">
                                                                            <Ellipse.Effect>
                                                                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.25" Color="#3C4043"/>
                                                                            </Ellipse.Effect>
                                                                        </Ellipse>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Track.Thumb>
                                                    </Track>
                                                </Grid>
                                            </ControlTemplate>
                                        </Slider.Template>
                                    </Slider>

                                    <Rectangle Grid.Column="2" Width="16" Height="10" Fill="#5F6368" RadiusX="2" RadiusY="2" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <!-- 3. POPOVER HÌNH KHỐI -->
                        <Border x:Name="ShapesPopover" 
                    Background="#FFFFFF" CornerRadius="12" Margin="12,85,0,0" Padding="16" Width="220" Height="241"
                    VerticalAlignment="Top"
                    Visibility="{Binding IsShapesPopoverVisible, Converter={StaticResource BoolToVis}}"
                    d:Visibility="Hidden">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.15" Color="#3C4043"/>
                            </Border.Effect>

                            <StackPanel>
                                <!-- KHU VỰC 1: Chọn Loại Hình (Shape) -->
                                <TextBlock Text="SHAPE" FontSize="12" FontWeight="Medium" Foreground="#5F6368" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">

                                    <!-- Vuông -->
                                    <RadioButton GroupName="ShapeTypes" Width="36" Height="36" Margin="0,0,4,0" IsChecked="True" ToolTip="Rectangle" 
                 Style="{StaticResource RadioToolStyle}"
                 Command="{Binding SelectShapeCommand}" CommandParameter="rectangle"
                 Content="M 4 4 L 20 4 L 20 20 L 4 20 Z"/>

                                    <!-- Tròn -->
                                    <RadioButton GroupName="ShapeTypes" Width="36" Height="36" Margin="0,0,4,0" ToolTip="Circle" 
                 Style="{StaticResource RadioToolStyle}"
                 Command="{Binding SelectShapeCommand}" CommandParameter="circle"
                 Content="M 12 2 A 10 10 0 1 1 12 22 A 10 10 0 1 1 12 2 Z"/>

                                    <!-- Tam giác -->
                                    <RadioButton GroupName="ShapeTypes" Width="36" Height="36" Margin="0,0,4,0" ToolTip="Triangle" 
                 Style="{StaticResource RadioToolStyle}"
                 Command="{Binding SelectShapeCommand}" CommandParameter="triangle"
                 Content="M 12 2 L 22 20 L 2 20 Z"/>

                                    <!-- Đường thẳng -->
                                    <RadioButton GroupName="ShapeTypes" Width="36" Height="36" ToolTip="Line" 
                 Style="{StaticResource RadioToolStyle}"
                 Command="{Binding SelectShapeCommand}" CommandParameter="line"
                 Content="M 2 12 L 22 12"/>

                                </StackPanel>

                                <!-- KHU VỰC 2: Chọn Màu Nền (Fill) và Màu Viền (Stroke) -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!-- Chia đều 2 ô màu ra 2 bên, cách nhau 12px -->
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- FILL (Màu nền) -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="FILL" FontSize="12" FontWeight="Medium" Foreground="#5F6368" Margin="0,0,0,8"/>
                                        <Button Command="{Binding ToggleShapeFillPaletteCommand}" Style="{StaticResource OutlinedColorButtonStyle}" Background="Transparent" BorderBrush="#DADCE0" BorderThickness="1" Cursor="Hand" Padding="5" HorizontalContentAlignment="Stretch">
                                            <!-- TODO: Bind Background tới thuộc tính ShapeFillColor trong ViewModel -->
                                            <Border Height="20" Background="#FF1AE8C3" CornerRadius="4" BorderBrush="#DADCE0" BorderThickness="0" SnapsToDevicePixels="True"/>
                                        </Button>
                                    </StackPanel>

                                    <!-- STROKE (Màu viền) -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="STROKE" FontSize="12" FontWeight="Medium" Foreground="#5F6368" Margin="0,0,0,8" />
                                        <Button Command="{Binding ToggleShapeStrokePaletteCommand}" Style="{StaticResource OutlinedColorButtonStyle}" Background="Transparent" BorderBrush="#DADCE0" BorderThickness="1" Cursor="Hand" Padding="5" HorizontalContentAlignment="Stretch">
                                            <!-- TODO: Bind Background tới thuộc tính ShapeStrokeColor trong ViewModel -->
                                            <Border Height="20" Background="#202124" CornerRadius="4" BorderBrush="#DADCE0" BorderThickness="0" SnapsToDevicePixels="True"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="THICKNESS" FontSize="12" FontWeight="Medium" Foreground="#5F6368" Margin="0,16,0,16"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" Data="M0,0 L16,0" Stroke="#5F6368" StrokeThickness="1" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="1" Maximum="20" Value="{Binding PenThickness, Mode=TwoWay}" Margin="8,0" Foreground="#1A73E8">
                                        <!-- Slider -->
                                        <Slider.Template>
                                            <ControlTemplate TargetType="Slider">
                                                <Grid VerticalAlignment="Center">
                                                    <Border Height="4" Background="#DADCE0" CornerRadius="2" VerticalAlignment="Center"/>
                                                    <Track x:Name="PART_Track">
                                                        <Track.DecreaseRepeatButton>
                                                            <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                                                <RepeatButton.Template>
                                                                    <ControlTemplate TargetType="RepeatButton">
                                                                        <Border Height="4" Background="#1A73E8" CornerRadius="2,0,0,2" VerticalAlignment="Center"/>
                                                                    </ControlTemplate>
                                                                </RepeatButton.Template>
                                                            </RepeatButton>
                                                        </Track.DecreaseRepeatButton>
                                                        <Track.IncreaseRepeatButton>
                                                            <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                                                <RepeatButton.Template>
                                                                    <ControlTemplate TargetType="RepeatButton">
                                                                        <Border Background="Transparent"/>
                                                                    </ControlTemplate>
                                                                </RepeatButton.Template>
                                                            </RepeatButton>
                                                        </Track.IncreaseRepeatButton>
                                                        <Track.Thumb>
                                                            <Thumb>
                                                                <Thumb.Template>
                                                                    <ControlTemplate TargetType="Thumb">
                                                                        <Ellipse Width="14" Height="14" Fill="#1A73E8">
                                                                            <Ellipse.Effect>
                                                                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.25" Color="#3C4043"/>
                                                                            </Ellipse.Effect>
                                                                        </Ellipse>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Track.Thumb>
                                                    </Track>
                                                </Grid>
                                            </ControlTemplate>
                                        </Slider.Template>
                                    </Slider>
                                    <Path Grid.Column="2" Data="M0,0 L18,0" Stroke="#5F6368" StrokeThickness="4" VerticalAlignment="Center"/>
                                </Grid>

                            </StackPanel>
                        </Border>
                        <!-- 4. POPOVER VĂN BẢN -->
                        <Border x:Name="TextPopover" 
                    Background="#FFFFFF" CornerRadius="12" Margin="12,194,0,0" Padding="16" Width="220"
                    VerticalAlignment="Top"
                    Visibility="{Binding IsTextPopoverVisible, Converter={StaticResource BoolToVis}}"
                    d:Visibility="Visible">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.15" Color="#3C4043"/>
                            </Border.Effect>

                            <StackPanel>
                                <!-- Font Family -->
                                <TextBlock Text="FONT FAMILY" FontSize="12" FontWeight="Medium" Foreground="#5F6368" Margin="0,0,0,8"/>

                                <!-- COMBOBOX GIAO DIỆN MỚI -->
                                <ComboBox SelectedIndex="0" Margin="0,0,0,16" 
                              Style="{StaticResource MaterialComboBoxStyle}" 
                              ItemContainerStyle="{StaticResource MaterialComboBoxItemStyle}">
                                    <ComboBoxItem Content="Roboto"/>
                                    <ComboBoxItem Content="Inter"/>
                                    <ComboBoxItem Content="Arial"/>
                                    <ComboBoxItem Content="Georgia"/>
                                </ComboBox>

                                <!-- Font Size -->
                                <TextBlock Text="FONT SIZE" FontSize="12" FontWeight="Medium" Foreground="#5F6368" Margin="0,0,0,8"/>

                                <!-- COMBOBOX GIAO DIỆN MỚI -->
                                <ComboBox SelectedIndex="2" Margin="0,0,0,16" 
                              Style="{StaticResource MaterialComboBoxStyle}" 
                              ItemContainerStyle="{StaticResource MaterialComboBoxItemStyle}">
                                    <ComboBoxItem Content="12pt"/>
                                    <ComboBoxItem Content="14pt"/>
                                    <ComboBoxItem Content="16pt"/>
                                    <ComboBoxItem Content="24pt"/>
                                </ComboBox>

                                <!-- Text Color -->
                                <TextBlock Text="TEXT COLOR" FontSize="12" FontWeight="Medium" Foreground="#5F6368" Margin="0,0,0,8"/>

                                <Button Command="{Binding ToggleTextColorPaletteCommand}" Style="{StaticResource OutlinedColorButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Khối vuông hiển thị màu -->
                                        <!-- TODO: Bind Background tới TextColor -->
                                        <Border Width="20" Height="20" Background="#202124" CornerRadius="4" BorderBrush="#DADCE0" BorderThickness="0" Margin="0,0,8,0" SnapsToDevicePixels="True"/>

                                        <TextBlock Text="Choose color" Foreground="#5F6368" VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>

            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#E8EAED" BorderThickness="1,0,0,0" Panel.ZIndex="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Network Status" FontSize="14" FontWeight="Medium" Foreground="#202124" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding NetworkLogs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Foreground="#5F6368" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Live Chat" FontSize="15" FontWeight="Medium" Foreground="#202124" Margin="0,0,0,16"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ChatMessages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="{Binding User}" FontSize="12" FontWeight="Medium" Foreground="#202124"/>
                                                <TextBlock Text="{Binding Time}" FontSize="12" Foreground="#5F6368" Margin="8,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Message}" FontSize="13" Foreground="#5F6368" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Border Grid.Row="2" BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,16,0,0">
                            <Grid>
                                <TextBox x:Name="txtChatInput" 
             Background="Transparent" BorderThickness="0" Foreground="#202124" FontSize="13" 
             VerticalContentAlignment="Center" Margin="0,0,40,0"/>

                                <TextBlock Text="Type a message..." Foreground="#9AA0A6" FontSize="13" 
               VerticalAlignment="Center" Margin="5,0,40,0" 
               IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtChatInput}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Button HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" 
            Cursor="Hand" Panel.ZIndex="2" Style="{StaticResource VectorToolStyle}">
                                    <Path Data="M 22,2 L 11,13 M 22,2 L 15,22 L 11,13 L 2,9 Z"
      Stroke="#B0B3B8" 
      StrokeThickness="1.5"
      StrokeLineJoin="Round"
      StrokeStartLineCap="Round"
      StrokeEndLineCap="Round"
      Fill="Transparent"
      Stretch="Uniform"
      Width="18" Height="18"
      Margin="-2,0,0,0"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        <!-- ================= OCR TOAST NOTIFICATION ================= -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" 
                Margin="0,0,0,40" Padding="24,12" MinWidth="220" 
                Background="#202124" CornerRadius="22" Panel.ZIndex="999"
                Visibility="{Binding IsOcrToastVisible, Converter={StaticResource BoolToVis}}"
                d:Visibility="Visible" Grid.Row="1" Width="284" Height="53">

            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="#3C4043"/>
            </Border.Effect>

            <TextBlock Text="Draw words to detect text" 
                               Foreground="#FFFFFF" FontSize="14" 
                               HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0,0,0"/>
        </Border>
        <!-- ================= POPOVER PROFILE / LOG OUT ================= -->
        <Border x:Name="ProfilePopover"
                Background="#FFFFFF" CornerRadius="8" MinWidth="160"
                HorizontalAlignment="Right" VerticalAlignment="Top" 
                Margin="0,52,24,0" Padding="0"
            Panel.ZIndex="1000"
                Visibility="{Binding IsProfilePopoverVisible, Converter={StaticResource BoolToVis}}"
                d:Visibility="Visible" Grid.RowSpan="2" Height="50" Width="180">

            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="#3C4043"/>
            </Border.Effect>

            <StackPanel>
                <Button Command="{Binding LogoutCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Stretch" Height="50">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bgBorder" Background="{TemplateBinding Background}" Padding="16,12" CornerRadius="8" SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Path Grid.Column="0" 
                                          Data="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4 M16 17l5-5-5-5 M21 12H9" 
                                          Stroke="#5F6368" StrokeThickness="1.5" 
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Fill="Transparent" 
                                          Width="18" Height="18" Stretch="Uniform" Margin="9,4,9,4"/>

                                    <TextBlock Grid.Column="1" 
                                               Text="Log out" 
                                               FontSize="14" 
                                               FontWeight="Regular"
                                               Foreground="#202124" Margin="10,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bgBorder" Property="Background" Value="#F8F9FA"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>