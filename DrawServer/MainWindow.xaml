<Window x:Class="DrawServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Server"
        Height="200"
        Width="300">

    <StackPanel Margin="10" RenderTransformOrigin="0.5,0.5">
        <StackPanel.RenderTransform>
            <TransformGroup>
                <ScaleTransform/>
                <SkewTransform/>
                <RotateTransform Angle="0.233"/>
                <TranslateTransform/>
            </TransformGroup>
        </StackPanel.RenderTransform>

        <TextBox Name="txtPort"
                 Text="5000"
                 Margin="0,0,0,10"/>

        <Button Content="Start Server"
                Click="btnStart_Click"/>

    </StackPanel>

</Window>